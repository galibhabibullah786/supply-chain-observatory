# ============================================================================
# Supply Chain Observatory — environment configuration
# ============================================================================
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is git-ignored. NEVER commit real secrets.
# All variables are read by the backend at startup; missing values fall back
# to the defaults noted below.
# ============================================================================


# ----------------------------------------------------------------------------
# HTTP server
# ----------------------------------------------------------------------------
# Port the Express server listens on. Used by src/server.js.
# Default if unset: 8080
PORT=8080


# ----------------------------------------------------------------------------
# Gemini API (Google AI for Developers)
# ----------------------------------------------------------------------------
# Required for any AI-assisted analysis to actually run.
# Get a key at: https://aistudio.google.com/apikey
#
# Read by src/clients/geminiClient.js (wraps @google/genai).
GEMINI_API_KEY=

# Gemini model name used by ThreatAnalyst for exploitability scoring.
# Read by src/agents/threatAnalyst.js.
# Default if unset: gemini-2.0-flash
# Other reasonable choices: gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.0-flash


# ----------------------------------------------------------------------------
# NVD (National Vulnerability Database) REST API v2.0
# ----------------------------------------------------------------------------
# Recommended but optional — the pipeline works without it but with stricter
# NVD rate limits (4 req / 30s vs. 48 req / 30s with a key).
# Get a free key at: https://nvd.nist.gov/developers/request-an-api-key
#
# Read by src/clients/nvdClient.js — passed in the `apiKey` request header.
NVD_API_KEY=


# ----------------------------------------------------------------------------
# Test-only overrides (do NOT set these in production)
# ----------------------------------------------------------------------------
# Bypasses the NVD client sliding-window rate limiter so unit tests can fire
# many concurrent lookups without queueing into a stall. Only honored when
# this variable is a positive integer.
# Read by src/clients/nvdClient.js.
# Default if unset: 4 (unkeyed) or 48 (keyed)
# Example for tests: NVD_TEST_MAX_REQUESTS=10000
NVD_TEST_MAX_REQUESTS=